{
  "name": "@homefinder/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "lint": "echo \"(api) no lint configured yet\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "sam:build": "sam build",
    "sam:local": "sam local start-api --port 3001"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1075.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@homefinder/logger": "workspace:*",
    "@homefinder/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "express": "^4.21.2",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
