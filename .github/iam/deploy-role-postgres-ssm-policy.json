{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadPostgresConnectionParams",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": "arn:aws:ssm:eu-west-2:020844256789:parameter/production/cribsearch/service/postgres/*"
    },
    {
      "Sid": "DecryptPostgresSecureStrings",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEquals": { "kms:ViaService": "ssm.eu-west-2.amazonaws.com" }
      }
    }
  ]
}
