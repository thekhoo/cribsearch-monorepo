# ─── Backend (apps/api) ────────────────────────────────────────────────
# Local Postgres (docker-compose). Used by Atlas migrations now and the
# app's pg driver later.
DATABASE_URL="postgresql://cribsearch:cribsearch@localhost:5432/cribsearch_local"
# Postgres fields for the API service (local dev). The service assembles the URL.
PGHOST="localhost"
PGPORT="5432"
PGUSER="cribsearch"
PGPASSWORD="cribsearch"
PGDATABASE="cribsearch_local"
# Supabase credentials (local dev only — Lambda reads from SSM)
SUPABASE_URL="https://your-project-ref.supabase.co"
# Server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Local dev server port
PORT=3001
# Log level: error | warn | info | debug (default: info)
LOG_LEVEL="info"

# ─── Frontend (apps/web) ───────────────────────────────────────────────
# Base URL of the deployed API (API Gateway URL in prod, localhost in dev)
NEXT_PUBLIC_API_URL="http://localhost:3001"
